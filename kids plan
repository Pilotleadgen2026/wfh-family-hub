}

function toggleTimer() {
  if (timerRunning) {
    clearInterval(timerInterval);
    timerRunning = false;
    document.getElementById('timer-toggle').textContent = '▶ Resume';
  } else {
    timerRunning = true;
    document.getElementById('timer-toggle').textContent = '⏸ Pause';
    timerInterval = setInterval(function() {
      if (timerSecs > 0) {
        timerSecs--;
        updateTimerDisplay();
        if (timerSecs % 60 === 0) { focusMinutes++; updateStats(); }
      } else {
        clearInterval(timerInterval);
        timerRunning = false;
        document.getElementById('timer-status').textContent = 'Done! Take a break.';
        document.getElementById('timer-toggle').textContent = '▶ Start';
        alert('Focus block complete! Great work.');
