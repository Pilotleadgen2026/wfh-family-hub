// ── AUDIO ENGINE ──────────────────────────────────────
function getAudioCtx() {
  if (!audioCtx) {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    masterGain = audioCtx.createGain();
    masterGain.gain.value = 0.6;
    masterGain.connect(audioCtx.destination);
  }
  return audioCtx;
}

function stopAllSounds() {
  for (var i = 0; i < currentNodes.length; i++) {
    try { currentNodes[i].stop(); } catch(e) {}
  }
  currentNodes = [];
}

function updateVolume(v) {
  document.getElementById('vol-label').textContent = v;
  if (masterGain) masterGain.gain.value = v / 100;
}

// White / Brown / Fan noise
function playNoise(tint) {
  var ctx = getAudioCtx();
  var bufSize = ctx.sampleRate * 2;
  var buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
  var data = buf.getChannelData(0);
  if (tint === 'white') {
    for (var i = 0; i < bufSize; i++) data[i] = Math.random() * 2 - 1;
  } else if (tint === 'brown') {
    var last = 0;
    for (var i = 0; i < bufSize; i++) { var w = Math.random() * 2 - 1; last = (last + 0.02 * w) / 1.02; data[i] = last * 3.5; }
  } else if (tint === 'fan') {
    var last = 0;
    for (var i = 0; i < bufSize; i++) { var w = Math.random() * 2 - 1; last = (last + 0.04 * w) / 1.04; data[i] = last * 2.5; }
  }
  var src = ctx.createBufferSource();
  src.buffer = buf; src.loop = true;
  var filter = ctx.createBiquadFilter();
  if (tint === 'fan') { filter.type = 'lowpass'; filter.frequency.value = 400; }
  else { filter.type = 'highshelf'; filter.frequency.value = 6000; filter.gain.value = tint === 'brown' ? -12 : 2; }
  src.connect(filter); filter.connect(masterGain);
  src.start();
  currentNodes.push(src);
}

// Rain sound
function playRain() {
  var ctx = getAudioCtx();
  var bufSize = ctx.sampleRate * 2;
  var buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
  var data = buf.getChannelData(0);
  for (var i = 0; i < bufSize; i++) data[i] = (Math.random() * 2 - 1) * 0.8;
  var src = ctx.createBufferSource(); src.buffer = buf; src.loop = true;
  var hi = ctx.createBiquadFilter(); hi.type = 'bandpass'; hi.frequency.value = 3500; hi.Q.value = 0.5;
  var lo = ctx.createBiquadFilter(); lo.type = 'lowpass'; lo.frequency.value = 8000;
  src.connect(hi); hi.connect(lo); lo.connect(masterGain);
  src.start(); currentNodes.push(src);
  var buf2 = ctx.createBuffer(1, bufSize, ctx.sampleRate);
  var d2 = buf2.getChannelData(0);
  var last = 0;
  for (var i = 0; i < bufSize; i++) { var w = Math.random() * 2 - 1; last = (last + 0.01 * w) / 1.01; d2[i] = last * 4; }
  var src2 = ctx.createBufferSource(); src2.buffer = buf2; src2.loop = true;
  var lp = ctx.createBiquadFilter(); lp.type = 'lowpass'; lp.frequency.value = 300;
  var g2 = ctx.createGain(); g2.gain.value = 0.4;
  src2.connect(lp); lp.connect(g2); g2.connect(masterGain);
  src2.start(); currentNodes.push(src2);
}

// Helper: play one melody note
function playNote(ctx, freq, startTime, duration, gainNode, wave) {
  var osc = ctx.createOscillator();
  var env = ctx.createGain();
  osc.type = wave || 'sine';
  osc.frequency.value = freq;
  env.gain.setValueAtTime(0, startTime);
  env.gain.linearRampToValueAtTime(0.18, startTime + 0.06);
  env.gain.setValueAtTime(0.18, startTime + duration - 0.08);
  env.gain.linearRampToValueAtTime(0, startTime + duration);
  osc.connect(env); env.connect(gainNode);
  osc.start(startTime); osc.stop(startTime + duration + 0.05);
  currentNodes.push(osc);
}

// Helper: soft pad chord
function playChord(ctx, freqs, startTime, duration, gainNode) {
  for (var fi = 0; fi < freqs.length; fi++) {
    var osc = ctx.createOscillator();
    var env = ctx.createGain();
    osc.type = 'sine'; osc.frequency.value = freqs[fi];
    env.gain.setValueAtTime(0, startTime);
    env.gain.linearRampToValueAtTime(0.04, startTime + 0.3);
    env.gain.setValueAtTime(0.04, startTime + duration - 0.3);
    env.gain.linearRampToValueAtTime(0, startTime + duration);
    osc.connect(env); env.connect(gainNode);
    osc.start(startTime); osc.stop(startTime + duration + 0.1);
    currentNodes.push(osc);
  }
}

// "Soft Dreams" — original lullaby in C pentatonic major
// C4=261.6 D4=293.7 E4=329.6 G4=392 A4=440 C5=523.2
function playSoftDreams() {
  var ctx = getAudioCtx();
  var mel = ctx.createGain(); mel.gain.value = 1.0; mel.connect(masterGain);

  var C4=261.6, D4=293.7, E4=329.6, G4=392, A4=440, C5=523.2, G3=196, A3=220;

  // Phrase A (11 notes, descending then ascending)
  var pA = [
    [C5,0,0.7],[A4,0.75,0.6],[G4,1.4,0.8],[E4,2.25,0.6],[D4,2.9,0.8],[C4,3.75,1.2],
    [D4,5.2,0.5],[E4,5.8,0.5],[G4,6.4,0.7],[A4,7.2,0.6],[C5,7.9,1.4]
  ];
  // Phrase B (ascending resolution)
  var pB = [
    [G4,0,0.6],[A4,0.7,0.5],[C5,1.3,0.8],[A4,2.2,0.5],[G4,2.8,0.6],
    [E4,3.5,0.8],[D4,4.4,0.5],[C4,5.0,1.5],[E4,6.8,0.5],[G4,7.4,0.5],[A4,8.0,0.6],[C5,8.7,1.6]
  ];
  // Chords
  var chords = [
    [[C4,E4,G4],0,2.5],[[G3,D4,G4],2.5,2.5],[[A3,C4,E4],5.0,2.5],[[G3,D4,G4],7.5,2.8]
  ];

  var loopLen = 11.0;
  var loopStart = ctx.currentTime + 0.1;
  var phraseLen = loopLen * 0.95;

  function scheduleOnce(startT) {
    for (var i = 0; i < pA.length; i++) playNote(ctx, pA[i][0], startT + pA[i][1], pA[i][2], mel, 'sine');
    for (var i = 0; i < chords.length; i++) playChord(ctx, chords[i][0], startT + chords[i][1], chords[i][2], mel);
    for (var i = 0; i < pB.length; i++) playNote(ctx, pB[i][0], startT + phraseLen + pB[i][1], pB[i][2], mel, 'sine');
    for (var i = 0; i < chords.length; i++) playChord(ctx, chords[i][0], startT + phraseLen + chords[i][1], chords[i][2], mel);
  }

  scheduleOnce(loopStart);
  var fullLoop = loopLen * 1.95;
  var lullTimer = setInterval(function() {
    if (activeNoise !== 3) { clearInterval(lullTimer); return; }
    loopStart += fullLoop;
    scheduleOnce(loopStart);
  }, fullLoop * 1000);
  currentNodes.push({ stop: function() { clearInterval(lullTimer); } });
}

// "Starlight" — original music-box lullaby in E major pentatonic
// E4=329.6 F#4=370 G#4=415.3 B4=493.9 C#5=554.4 E5=659.3
function playStarlight() {
  var ctx = getAudioCtx();
  var mel = ctx.createGain(); mel.gain.value = 0.9; mel.connect(masterGain);

  var E4=329.6, Fs4=370, Gs4=415.3, B4=493.9, Cs5=554.4, E5=659.3, B3=246.9, E3=164.8;

  // Phrase A — bright descending music-box
  var pA = [
    [E5,0,0.35],[Cs5,0.4,0.3],[B4,0.75,0.4],[Gs4,1.2,0.3],[Fs4,1.55,0.4],[E4,2.0,0.6],
    [Fs4,2.7,0.3],[Gs4,3.05,0.3],[B4,3.4,0.4],[Cs5,3.85,0.35],[E5,4.25,0.5],
    [B4,4.85,0.3],[Gs4,5.2,0.3],[Fs4,5.55,0.35],[E4,5.95,0.8]
  ];
  // Phrase B — ascending resolution
  var pB = [
    [Gs4,0,0.3],[B4,0.35,0.3],[E5,0.7,0.45],[Cs5,1.2,0.3],[B4,1.55,0.4],
    [Gs4,2.0,0.3],[Fs4,2.35,0.3],[E4,2.7,0.5],[Fs4,3.3,0.3],[Gs4,3.65,0.3],
    [B4,4.0,0.35],[E5,4.4,0.6],[Cs5,5.1,0.3],[B4,5.45,0.35],[E4,5.85,1.0]
  ];
  // Bass
  var bass = [[E3,0,1.2],[B3,1.4,1.0],[E3,2.6,1.0],[B3,3.8,1.0],[E3,5.0,1.5]];

  var loopLen = 7.0;
  var loopStart = ctx.currentTime + 0.1;
  var phraseLen = loopLen * 0.95;

  function scheduleOnce(startT) {
    for (var i = 0; i < pA.length; i++) playNote(ctx, pA[i][0], startT + pA[i][1], pA[i][2], mel, 'triangle');
    for (var i = 0; i < bass.length; i++) playNote(ctx, bass[i][0], startT + bass[i][1], bass[i][2], mel, 'sine');
    for (var i = 0; i < pB.length; i++) playNote(ctx, pB[i][0], startT + phraseLen + pB[i][1], pB[i][2], mel, 'triangle');
    for (var i = 0; i < bass.length; i++) playNote(ctx, bass[i][0], startT + phraseLen + bass[i][1], bass[i][2], mel, 'sine');
  }

  scheduleOnce(loopStart);
  var fullLoop = loopLen * 1.95;
  var lullTimer = setInterval(function() {
    if (activeNoise !== 4) { clearInterval(lullTimer); return; }
    loopStart += fullLoop;
    scheduleOnce(loopStart);
  }, fullLoop * 1000);
  currentNodes.push({ stop: function() { clearInterval(lullTimer); } });
}

// ── SOUNDS UI ─────────────────────────────────────────
var noises = [
  { name: 'Rain',         desc: 'Gentle rainfall — ideal for focus',         icon: '🌧' },
  { name: 'White noise',  desc: 'Consistent full-frequency mask',             icon: '〰' },
  { name: 'Brown noise',  desc: 'Deep low-frequency hum',                     icon: '🎧' },
  { name: 'Soft Dreams',  desc: 'Original lullaby — slow pentatonic melody',  icon: '🌸' },
  { name: 'Starlight',    desc: 'Original lullaby — music-box twinkle',       icon: '✨' },
  { name: 'Fan',          desc: 'Steady gentle fan hum',                      icon: '💨' }
];

function renderNoise() {
  var html = '';
  for (var i = 0; i < noises.length; i++) {
    var n = noises[i];
    var isActive = activeNoise === i;
    html += '<div class="noise-card' + (isActive ? ' active' : '') + '" onclick="selectNoise(' + i + ')">';
    html += '<div class="noise-icon">' + n.icon + '</div>';
    html += '<div style="flex:1"><div class="noise-name">' + n.name + '</div><div class="noise-desc">' + n.desc + '</div></div>';
    html += '<span class="badge ' + (isActive ? 'b-teal' : 'b-gray') + '">' + (isActive ? '⏹ Stop' : '▶ Play') + '</span>';
    html += '</div>';
  }
  document.getElementById('noise-list').innerHTML = html;
}

function selectNoise(i) {
  if (activeNoise === i) {
    stopAllSounds();
    activeNoise = null;
  } else {
    activeNoise = i;
    stopAllSounds();
    if (i === 0) playRain();
    else if (i === 1) playNoise('white');
    else if (i === 2) playNoise('brown');
    else if (i === 3) playSoftDreams();
    else if (i === 4) playStarlight();
    else if (i === 5) playNoise('fan');
  }
  renderNoise();
}

// ── NOISE METER ───────────────────────────────────────
function animateNoise() {
  noiseLevel = Math.min(100, Math.max(5, noiseLevel + (Math.random() * 16 - 8)));
  var p = Math.round(noiseLevel);
  var fill = document.getElementById('noise-fill');
  var txt = document.getElementById('noise-text');
  if (fill) fill.style.width = p + '%';
  if (fill) fill.style.background = p < 30 ? 'var(--teal)' : p < 60 ? 'var(--amber)' : 'var(--rose)';
  if (txt) txt.textContent = p < 30 ? 'Quiet — great for video calls' : p < 60 ? 'Moderate — okay for most calls' : 'Loud — use headphones or move rooms';
  noiseAnimTimer = setTimeout(animateNoise, 1400);
}

// ── INIT ──────────────────────────────────────────────
updateTimerDisplay();
renderNoise();
animateNoise();
updateStats();
</script>
</body>
