<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WFH Family Hub</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #0f0f1a;
  --bg2: #1a1a2e;
  --bg3: #16213e;
  --card: #1e1e35;
  --card2: #252540;
  --text: #f0f0ff;
  --text2: #9898bb;
  --border: rgba(255,255,255,0.08);
  --border2: rgba(255,255,255,0.15);
  --gold: #f5c842;
  --gold2: #e6a817;
  --violet: #7c5cbf;
  --violet2: #9b7de0;
  --violet3: #c4a8ff;
  --teal: #00c9a7;
  --teal2: #00a88c;
  --rose: #ff6b8a;
  --rose2: #e84d6e;
  --amber: #ff9f43;
  --blue: #4facfe;
  --green: #43e97b;
  --radius: 10px;
  --radius-lg: 16px;
  --radius-xl: 22px;
}
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
.app { max-width: 740px; margin: 0 auto; padding: 1.5rem 1rem 3rem; }

.header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; padding-bottom: 1.25rem; border-bottom: 1px solid var(--border); }
.logo { font-size: 22px; font-weight: 700; }
.logo .wfh { color: var(--text2); }
.logo .hub { background: linear-gradient(135deg, var(--violet3), var(--teal)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

.tabs { display: flex; gap: 5px; background: var(--bg2); padding: 5px; border-radius: var(--radius-lg); margin-bottom: 1.75rem; overflow-x: auto; border: 1px solid var(--border); }
.tab { flex: 1; min-width: 68px; padding: 9px 8px; border: none; background: transparent; border-radius: var(--radius); font-size: 12px; font-weight: 500; cursor: pointer; color: var(--text2); transition: all .2s; white-space: nowrap; }
.tab.active { background: linear-gradient(135deg, var(--violet), #5a3fa0); color: #fff; font-weight: 600; box-shadow: 0 4px 15px rgba(124,92,191,0.4); }
.tab:hover:not(.active) { color: var(--text); background: var(--card2); }
.panel { display: none; } .panel.active { display: block; }

.cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-bottom: 1.75rem; }
.metric { border-radius: var(--radius-lg); padding: 16px 18px; }
.metric-gold { background: linear-gradient(135deg, #2a2010, #3a2e10); border: 1px solid rgba(245,200,66,0.3); }
.metric-teal { background: linear-gradient(135deg, #0a2520, #102e28); border: 1px solid rgba(0,201,167,0.3); }
.metric-rose { background: linear-gradient(135deg, #2a0f18, #3a1020); border: 1px solid rgba(255,107,138,0.3); }
.metric-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 8px; }
.metric-gold .metric-label { color: var(--gold); }
.metric-teal .metric-label { color: var(--teal); }
.metric-rose .metric-label { color: var(--rose); }
.metric-value { font-size: 26px; font-weight: 700; color: var(--text); }
.metric-sub { font-size: 11px; color: var(--text2); margin-top: 3px; }

.card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.25rem 1.5rem; margin-bottom: 14px; }
.card-title { font-size: 15px; font-weight: 700; margin-bottom: 14px; color: var(--text); }
.flex-between { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }

.btn { display: inline-flex; align-items: center; gap: 7px; padding: 9px 18px; border-radius: var(--radius); font-size: 13px; font-weight: 600; cursor: pointer; transition: all .18s; border: none; }
.btn-violet { background: linear-gradient(135deg, var(--violet), #5a3fa0); color: #fff; box-shadow: 0 4px 15px rgba(124,92,191,0.35); }
.btn-violet:hover { box-shadow: 0 6px 20px rgba(124,92,191,0.55); transform: translateY(-1px); }
.btn-gold { background: linear-gradient(135deg, var(--gold), var(--gold2)); color: #1a1200; box-shadow: 0 4px 15px rgba(245,200,66,0.35); }
.btn-gold:hover { box-shadow: 0 6px 20px rgba(245,200,66,0.5); transform: translateY(-1px); }
.btn-teal { background: linear-gradient(135deg, var(--teal), var(--teal2)); color: #001a16; box-shadow: 0 4px 15px rgba(0,201,167,0.3); }
.btn-teal:hover { box-shadow: 0 6px 20px rgba(0,201,167,0.45); transform: translateY(-1px); }
.btn-rose { background: linear-gradient(135deg, var(--rose), var(--rose2)); color: #fff; box-shadow: 0 4px 15px rgba(255,107,138,0.3); }
.btn-rose:hover { box-shadow: 0 6px 20px rgba(255,107,138,0.45); transform: translateY(-1px); }
.btn-amber { background: linear-gradient(135deg, var(--amber), #e8892a); color: #1a0800; box-shadow: 0 4px 15px rgba(255,159,67,0.3); }
.btn-amber:hover { box-shadow: 0 6px 20px rgba(255,159,67,0.45); transform: translateY(-1px); }
.btn-outline { background: transparent; border: 1px solid var(--border2); color: var(--text2); }
.btn-outline:hover { background: var(--card2); color: var(--text); }
.btn-sm { padding: 6px 13px; font-size: 12px; }
.btn-group { display: flex; gap: 10px; flex-wrap: wrap; }

input[type="text"], input[type="time"], select {
  width: 100%; padding: 11px 14px; border: 1px solid var(--border2); border-radius: var(--radius);
  background: var(--bg2); color: var(--text); font-size: 13px; margin-bottom: 10px;
  outline: none; font-family: inherit; transition: border-color .15s;
}
input:focus, select:focus { border-color: var(--violet2); box-shadow: 0 0 0 3px rgba(124,92,191,0.15); }
select option { background: var(--bg2); }

.row { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--border); }
.row:last-child { border-bottom: none; }
.avatar { width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 15px; font-weight: 700; flex-shrink: 0; }
.av-0 { background: linear-gradient(135deg, #7c5cbf, #5a3fa0); color: #fff; }
.av-1 { background: linear-gradient(135deg, #00c9a7, #00a88c); color: #001a16; }
.av-2 { background: linear-gradient(135deg, #ff6b8a, #e84d6e); color: #fff; }
.av-3 { background: linear-gradient(135deg, #f5c842, #e6a817); color: #1a1200; }
.row-name { font-size: 13px; font-weight: 600; flex: 1; }
.badge { font-size: 11px; padding: 4px 10px; border-radius: 20px; font-weight: 600; }
.b-green { background: rgba(67,233,123,0.15); color: var(--green); border: 1px solid rgba(67,233,123,0.25); }
.b-amber { background: rgba(255,159,67,0.15); color: var(--amber); border: 1px solid rgba(255,159,67,0.25); }
.b-blue  { background: rgba(79,172,254,0.15); color: var(--blue);  border: 1px solid rgba(79,172,254,0.25); }
.b-violet{ background: rgba(124,92,191,0.15); color: var(--violet3);border: 1px solid rgba(124,92,191,0.25); }
.b-gray  { background: rgba(255,255,255,0.06);color: var(--text2); border: 1px solid var(--border); }
.b-teal  { background: rgba(0,201,167,0.15);  color: var(--teal);  border: 1px solid rgba(0,201,167,0.25); }

.status-sel { font-size:12px; padding:5px 10px; border:1px solid var(--border2); border-radius:8px; background:var(--bg2); color:var(--text); cursor:pointer; margin-bottom:0; width:auto; }

.tip { background: linear-gradient(135deg, rgba(124,92,191,0.10), rgba(0,201,167,0.07)); border: 1px solid rgba(124,92,191,0.22); border-radius: var(--radius-lg); padding: 13px 16px; font-size: 13px; color: var(--text2); margin-bottom: 14px; line-height: 1.6; }
.tip strong { color: var(--violet3); }

.sch-row { display: grid; grid-template-columns: 65px 1fr; margin-bottom: 4px; }
.sch-time { font-size: 11px; color: var(--text2); padding-top: 9px; font-weight: 600; }
.sch-block { border-radius: 8px; padding: 8px 12px; margin-bottom: 4px; }
.sch-title { font-size: 12px; font-weight: 700; }
.sch-who { font-size: 11px; opacity: .7; margin-top: 1px; }

.timer-wrap { text-align: center; padding: 1rem 0 .5rem; }
.timer-ring { position: relative; display: inline-flex; align-items: center; justify-content: center; width: 190px; height: 190px; margin-bottom: 1.5rem; }
.timer-ring svg { position: absolute; top: 0; left: 0; transform: rotate(-90deg); }
.timer-num { font-size: 40px; font-weight: 800; background: linear-gradient(135deg, var(--violet3), var(--teal)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.timer-lbl { font-size: 12px; color: var(--text2); margin-top: 4px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }

.task-item { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--border); }
.task-item:last-child { border-bottom: none; }
.task-check { width: 22px; height: 22px; border-radius: 6px; border: 2px solid var(--border2); cursor: pointer; flex-shrink: 0; display: flex; align-items: center; justify-content: center; transition: all .18s; }
.task-check.done { background: linear-gradient(135deg, var(--violet), #5a3fa0); border-color: var(--violet); box-shadow: 0 2px 10px rgba(124,92,191,0.4); }
.task-check.done::after { content:''; width:5px; height:10px; border:2px solid #fff; border-top:none; border-left:none; transform:rotate(45deg); display:block; margin-top:-2px; }
.task-text { font-size: 13px; flex: 1; }
.task-text.done { text-decoration: line-through; color: var(--text2); }
.section-kid { margin-bottom: 16px; }
.section-kid-name { font-size: 11px; font-weight: 700; color: var(--violet3); text-transform: uppercase; letter-spacing: .07em; margin-bottom: 6px; }

.noise-card { background: var(--card2); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 14px 16px; margin-bottom: 8px; display: flex; align-items: center; gap: 14px; cursor: pointer; transition: all .18s; }
.noise-card:hover { border-color: var(--border2); }
.noise-card.active { background: linear-gradient(135deg, rgba(0,201,167,0.1), rgba(124,92,191,0.08)); border-color: var(--teal); box-shadow: 0 0 20px rgba(0,201,167,0.1); }
.noise-icon { width: 42px; height: 42px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; background: var(--bg2); border: 1px solid var(--border2); }
.noise-name { font-size: 13px; font-weight: 700; }
.noise-desc { font-size: 11px; color: var(--text2); margin-top: 2px; }
.progress-bar { height: 8px; background: var(--bg2); border-radius: 4px; overflow: hidden; margin: 10px 0 6px; }
.progress-fill { height: 100%; border-radius: 4px; transition: width .4s, background .4s; }

.mood-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 8px; margin-bottom: 14px; }
.mood-btn { padding: 12px 4px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--card2); cursor: pointer; text-align: center; transition: all .18s; }
.mood-btn:hover { border-color: var(--border2); }
.mood-btn.sel { background: linear-gradient(135deg, rgba(124,92,191,0.2), rgba(0,201,167,0.1)); border-color: var(--violet2); box-shadow: 0 0 15px rgba(124,92,191,0.2); }
.mood-emoji { font-size: 22px; }
.mood-lbl { font-size: 10px; color: var(--text2); margin-top: 4px; font-weight: 500; }

.upgrade-hero { background: linear-gradient(135deg, #1a0f35, #0d2535, #0f2a1e); border: 1px solid rgba(124,92,191,0.3); border-radius: var(--radius-xl); padding: 2rem; margin-bottom: 16px; }
.upgrade-hero h2 { font-size: 22px; font-weight: 800; margin-bottom: 6px; }
.upgrade-hero h2 span { background: linear-gradient(135deg, var(--gold), var(--amber)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.upgrade-hero p { font-size: 14px; color: var(--text2); line-height: 1.65; margin-bottom: 1.25rem; }
.price-tag { display: inline-flex; align-items: baseline; gap: 4px; margin-bottom: 1.25rem; }
.price-num { font-size: 44px; font-weight: 800; color: var(--gold); }
.price-period { font-size: 14px; color: var(--text2); }
.feature-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 1.25rem; }
.feature-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text2); }
.feat-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--teal); flex-shrink: 0; }
.feat-dot-gold { background: var(--gold); }

.comp-table { width: 100%; font-size: 13px; border-collapse: collapse; }
.comp-table th { text-align: left; padding: 10px 0; border-bottom: 1px solid var(--border); font-weight: 700; color: var(--text2); font-size: 11px; text-transform: uppercase; letter-spacing: .05em; }
.comp-table th:not(:first-child) { text-align: center; }
.comp-table td { padding: 10px 0; border-bottom: 1px solid var(--border); }
.comp-table td:not(:first-child) { text-align: center; }
.comp-table tr:last-child td { border-bottom: none; }
.pro-col { color: var(--violet3); font-weight: 700; }

input[type="range"] { width: 100%; cursor: pointer; accent-color: var(--violet2); }

@media (max-width: 500px) {
  .cards { grid-template-columns: 1fr 1fr; }
  .cards .metric:last-child { grid-column: span 2; }
  .feature-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>
<div class="app">

  <div class="header">
    <div class="logo"><span class="wfh">WFH</span> <span class="hub">Family Hub</span></div>
    <button class="btn btn-gold btn-sm" onclick="switchTab('upgrade')">✦ Upgrade to Pro</button>
  </div>

  <div class="tabs">
    <button class="tab active" onclick="switchTab('dashboard')">Dashboard</button>
    <button class="tab" onclick="switchTab('schedule')">Schedule</button>
    <button class="tab" onclick="switchTab('focus')">Focus</button>
    <button class="tab" onclick="switchTab('tasks')">Tasks</button>
    <button class="tab" onclick="switchTab('noise')">Sounds</button>
    <button class="tab" onclick="switchTab('upgrade')">⭐ Pro</button>
  </div>

  <!-- DASHBOARD -->
  <div id="dashboard" class="panel active">
    <div class="cards">
      <div class="metric metric-gold">
        <div class="metric-label">Focus time</div>
        <div class="metric-value" id="focus-today">0h 0m</div>
        <div class="metric-sub">Goal: 4 hours</div>
      </div>
      <div class="metric metric-teal">
        <div class="metric-label">Tasks done</div>
        <div class="metric-value" id="tasks-stat">0/0</div>
        <div class="metric-sub">Kids' tasks</div>
      </div>
      <div class="metric metric-rose">
        <div class="metric-label">Interruptions</div>
        <div class="metric-value" id="interrupt-count">0</div>
        <div class="metric-sub"><button class="btn btn-outline btn-sm" style="margin-top:5px" onclick="logInterrupt()">+ Log</button></div>
      </div>
    </div>

    <div class="tip"><strong>Welcome!</strong> Add your kids below, then head to <strong>Schedule</strong> to plan their day — so you can focus on yours.</div>

    <div class="card">
      <div class="flex-between">
        <div class="card-title">Kids at home</div>
        <button class="btn btn-violet btn-sm" onclick="showAddKid()">+ Add child</button>
      </div>
      <div id="kid-list"><p style="font-size:13px;color:var(--text2);padding:8px 0">No kids added yet. Click "+ Add child" to get started.</p></div>
    </div>

    <div id="add-kid-form" class="card" style="display:none;border-color:rgba(124,92,191,0.3)">
      <div class="card-title">Add a child</div>
      <input type="text" id="kid-name" placeholder="Child's name (e.g. Emma)">
      <input type="text" id="kid-age" placeholder="Age (e.g. 7)">
      <div class="btn-group">
        <button class="btn btn-violet" onclick="addKid()">Save child</button>
        <button class="btn btn-outline" onclick="document.getElementById('add-kid-form').style.display='none'">Cancel</button>
      </div>
    </div>

    <div class="card">
      <div class="card-title">Quick actions</div>
      <div class="btn-group">
        <button class="btn btn-violet btn-sm" onclick="switchTab('focus')">▶ Start focus</button>
        <button class="btn btn-teal btn-sm" onclick="switchTab('tasks')">+ Add task</button>
        <button class="btn btn-rose btn-sm" onclick="switchTab('noise')">♫ Sounds</button>
        <button class="btn btn-amber btn-sm" onclick="switchTab('schedule')">📅 Schedule</button>
      </div>
    </div>
  </div>

  <!-- SCHEDULE -->
  <div id="schedule" class="panel">
    <div class="card">
      <div class="flex-between">
        <div class="card-title">Today's schedule</div>
        <span class="badge b-violet" id="block-count">0 blocks</span>
      </div>
      <div id="schedule-blocks"><p style="font-size:13px;color:var(--text2);padding:8px 0">No blocks yet. Add one below.</p></div>
    </div>
    <div class="card" style="border-color:rgba(0,201,167,0.2)">
      <div class="card-title">Add a time block</div>
      <input type="time" id="block-time" value="09:00">
      <input type="text" id="block-title-input" placeholder="e.g. Quiet reading, Lego time, Snack break">
      <select id="block-who"><option value="parent">Parent — focus block</option><option value="all">All kids together</option></select>
      <button class="btn btn-teal" onclick="addBlock()" style="width:100%">+ Add to schedule</button>
    </div>
  </div>

  <!-- FOCUS -->
  <div id="focus" class="panel">
    <div class="card timer-wrap">
      <div class="card-title" style="text-align:left">Pomodoro focus timer</div>
      <div class="timer-ring">
        <svg width="190" height="190" viewBox="0 0 190 190">
          <defs>
            <linearGradient id="arcGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#c4a8ff"/>
              <stop offset="100%" stop-color="#00c9a7"/>
            </linearGradient>
          </defs>
          <circle cx="95" cy="95" r="82" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="10"/>
          <circle id="timer-arc" cx="95" cy="95" r="82" fill="none" stroke="url(#arcGrad)" stroke-width="10"
            stroke-linecap="round" stroke-dasharray="515" stroke-dashoffset="0"/>
        </svg>
        <div>
          <div class="timer-num" id="timer-display">25:00</div>
          <div class="timer-lbl" id="timer-status">Focus block</div>
        </div>
      </div>
      <div class="btn-group" style="justify-content:center;margin-bottom:1rem">
        <button class="btn btn-violet" id="timer-toggle" onclick="toggleTimer()">▶ Start</button>
        <button class="btn btn-outline" onclick="resetTimer()">Reset</button>
        <select id="timer-mode" onchange="setMode()" style="width:auto;margin-bottom:0">
          <option value="25">25 min focus</option>
          <option value="50">50 min deep work</option>
          <option value="5">5 min break</option>
          <option value="15">15 min break</option>
        </select>
      </div>
    </div>
    <div class="card">
      <div class="card-title">Kids mood check-in</div>
      <p style="font-size:13px;color:var(--text2);margin-bottom:14px">How is everyone feeling before your focus block?</p>
      <div id="mood-panel"><p style="font-size:13px;color:var(--text2)">Add kids on the Dashboard first.</p></div>
    </div>
  </div>

  <!-- TASKS -->
  <div id="tasks" class="panel">
    <div class="card">
      <div class="flex-between">
        <div class="card-title">Kids' task list</div>
        <span class="badge b-teal" id="tasks-badge">0 done</span>
      </div>
      <div id="task-list"><p style="font-size:13px;color:var(--text2);padding:8px 0">No tasks yet. Add one below.</p></div>
    </div>
    <div class="card" style="border-color:rgba(124,92,191,0.2)">
      <div class="card-title">Add a task</div>
      <input type="text" id="task-input" placeholder="e.g. Read for 20 min, Math worksheet, Draw a picture">
      <select id="task-who-select"><option value="">— Select a child —</option></select>
      <button class="btn btn-violet" onclick="addTask()" style="width:100%">+ Add task</button>
    </div>
    <div class="card">
      <div class="card-title">Activity ideas by age</div>
      <div style="font-size:13px;line-height:2">
        <span style="color:var(--violet3);font-weight:600">Ages 3–5:</span> <span style="color:var(--text2)">Playdough, colouring, sticker puzzles</span><br>
        <span style="color:var(--teal);font-weight:600">Ages 6–8:</span> <span style="color:var(--text2)">Lego, drawing, reading, board games</span><br>
        <span style="color:var(--amber);font-weight:600">Ages 9–11:</span> <span style="color:var(--text2)">Workbooks, craft kits, coding apps</span><br>
        <span style="color:var(--gold);font-weight:600">Ages 12+:</span> <span style="color:var(--text2)">Study blocks, online courses, cooking</span>
      </div>
    </div>
  </div>

  <!-- SOUNDS -->
  <div id="noise" class="panel">
    <div class="card">
      <div class="card-title">Focus sounds</div>
      <p style="font-size:13px;color:var(--text2);margin-bottom:14px">Mask household noise during work calls. Tap to select.</p>
      <div id="noise-list"></div>
      <div style="margin-top:16px">
        <div style="font-size:12px;color:var(--text2);margin-bottom:8px;font-weight:600">Volume — <span id="vol-label">60</span>%</div>
        <input type="range" min="0" max="100" value="60" oninput="document.getElementById('vol-label').textContent=this.value">
      </div>
    </div>
    <div class="card">
      <div class="card-title">Ambient noise level</div>
      <p style="font-size:13px;color:var(--text2);margin-bottom:4px">Live household noise estimate</p>
      <div class="progress-bar"><div class="progress-fill" id="noise-fill" style="width:40%;background:var(--teal)"></div></div>
      <div style="font-size:12px;color:var(--text2);font-weight:500" id="noise-text">Moderate — okay for most calls</div>
    </div>
  </div>

  <!-- UPGRADE -->
  <div id="upgrade" class="panel">
    <div class="upgrade-hero">
      <h2>WFH Family Hub <span>Pro</span></h2>
      <p>Unlock unlimited kids, AI-powered daily schedule builder, focus reports, email reminders, and calendar sync — everything a WFH parent needs to stay productive.</p>
      <div class="price-tag">
        <span class="price-num">$7</span>
        <span class="price-period">/ month</span>
      </div>
      <div>
        <button class="btn btn-gold" onclick="alert('Connect your Stripe account here to activate payments!')" style="font-size:15px;padding:13px 28px">✦ Get Pro Access</button>
      </div>
      <div class="feature-grid">
        <div class="feature-item"><div class="feat-dot"></div>Unlimited kid profiles</div>
        <div class="feature-item"><div class="feat-dot"></div>AI schedule generator</div>
        <div class="feature-item"><div class="feat-dot feat-dot-gold"></div>Weekly focus reports</div>
        <div class="feature-item"><div class="feat-dot feat-dot-gold"></div>20+ focus sounds</div>
        <div class="feature-item"><div class="feat-dot"></div>Email reminders</div>
        <div class="feature-item"><div class="feat-dot"></div>Google Calendar sync</div>
        <div class="feature-item"><div class="feat-dot feat-dot-gold"></div>Screen time tracking</div>
        <div class="feature-item"><div class="feat-dot feat-dot-gold"></div>Priority support</div>
      </div>
    </div>
    <div class="card">
      <div class="card-title">Free vs Pro</div>
      <table class="comp-table">
        <thead><tr><th>Feature</th><th>Free</th><th class="pro-col">Pro ✦</th></tr></thead>
        <tbody>
          <tr><td>Kid profiles</td><td style="color:var(--text2)">2</td><td class="pro-col">Unlimited</td></tr>
          <tr><td>Focus timer</td><td>✓</td><td class="pro-col">✓</td></tr>
          <tr><td>Task lists</td><td>✓</td><td class="pro-col">✓</td></tr>
          <tr><td>Focus sounds</td><td style="color:var(--text2)">5</td><td class="pro-col">20+</td></tr>
          <tr><td>AI schedule builder</td><td style="color:var(--text2)">—</td><td class="pro-col">✓</td></tr>
          <tr><td>Weekly reports</td><td style="color:var(--text2)">—</td><td class="pro-col">✓</td></tr>
          <tr><td>Email reminders</td><td style="color:var(--text2)">—</td><td class="pro-col">✓</td></tr>
          <tr><td>Calendar sync</td><td style="color:var(--text2)">—</td><td class="pro-col">✓</td></tr>
        </tbody>
      </table>
    </div>
  </div>

</div>

<script>
let kids=[],tasks=[],scheduleBlocks=[],interruptCount=0,focusMinutes=0;
let timerInterval=null,timerRunning=false,timerSecs=25*60,timerTotal=25*60;
let activeNoise=null,noiseLevel=40;

function switchTab(id){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.querySelectorAll('.tab').forEach(t=>{if(t.getAttribute('onclick')&&t.getAttribute('onclick').includes("'"+id+"'"))t.classList.add('active');});
  if(id==='focus')renderMoods();
  if(id==='tasks')renderTaskWhoSelect();
  if(id==='schedule')renderScheduleWhoSelect();
}

function showAddKid(){document.getElementById('add-kid-form').style.display='block';document.getElementById('kid-name').focus();}
function addKid(){
  const name=document.getElementById('kid-name').value.trim();
  const age=document.getElementById('kid-age').value.trim();
  if(!name)return;
  kids.push({name,age,status:'free play',av:kids.length%4});
  document.getElementById('kid-name').value='';document.getElementById('kid-age').value='';
  document.getElementById('add-kid-form').style.display='none';
  renderKids();renderTaskWhoSelect();renderScheduleWhoSelect();
}
const statusBadge={'studying':'b-green','free play':'b-blue','on break':'b-amber','done':'b-green'};
function renderKids(){
  const el=document.getElementById('kid-list');
  if(!kids.length){el.innerHTML='<p style="font-size:13px;color:var(--text2);padding:8px 0">No kids added yet. Click "+ Add child".</p>';return;}
  el.innerHTML=kids.map((k,i)=>`
    <div class="row">
      <div class="avatar av-${k.av}">${k.name[0]}</div>
      <div class="row-name">${k.name} <span style="font-weight:400;color:var(--text2);font-size:12px">${k.age?'age '+k.age:''}</span></div>
      <select class="status-sel" onchange="updateKidStatus(${i},this.value)">
        ${['free play','studying','on break','done'].map(s=>`<option value="${s}"${k.status===s?' selected':''}>${s}</option>`).join('')}
      </select>
      <span class="badge ${statusBadge[k.status]||'b-gray'}">${k.status}</span>
    </div>`).join('');
  updateStats();
}
function updateKidStatus(i,val){kids[i].status=val;renderKids();}

const blockPalette={parent:['rgba(0,201,167,0.12)','#00c9a7'],all:['rgba(245,200,66,0.12)','#f5c842']};
const kidPalette=[['rgba(124,92,191,0.15)','#c4a8ff'],['rgba(255,107,138,0.15)','#ff6b8a'],['rgba(79,172,254,0.15)','#4facfe'],['rgba(255,159,67,0.15)','#ff9f43']];
function renderScheduleWhoSelect(){
  const sel=document.getElementById('block-who');
  sel.innerHTML='<option value="parent">Parent — focus block</option><option value="all">All kids together</option>'+kids.map(k=>`<option value="${k.name}">${k.name}</option>`).join('');
}
function addBlock(){
  const time=document.getElementById('block-time').value;
  const title=document.getElementById('block-title-input').value.trim();
  const who=document.getElementById('block-who').value;
  if(!title){alert('Please enter an activity name.');return;}
  const color=blockPalette[who]||kidPalette[kids.findIndex(k=>k.name===who)%kidPalette.length]||kidPalette[0];
  scheduleBlocks.push({time,title,who,color});
  document.getElementById('block-title-input').value='';
  renderSchedule();
}
function renderSchedule(){
  const el=document.getElementById('schedule-blocks');
  const bc=document.getElementById('block-count');
  if(bc)bc.textContent=scheduleBlocks.length+' block'+(scheduleBlocks.length!==1?'s':'');
  if(!scheduleBlocks.length){el.innerHTML='<p style="font-size:13px;color:var(--text2);padding:8px 0">No blocks yet.</p>';return;}
  const sorted=[...scheduleBlocks].sort((a,b)=>a.time.localeCompare(b.time));
  el.innerHTML=sorted.map(b=>`
    <div class="sch-row">
      <div class="sch-time">${b.time}</div>
      <div class="sch-block" style="background:${b.color[0]};border:1px solid ${b.color[1]}33">
        <div class="sch-title" style="color:${b.color[1]}">${b.title}</div>
        <div class="sch-who" style="color:${b.color[1]}">${b.who}</div>
      </div>
    </div>`).join('');
}

function updateTimerDisplay(){
  const m=Math.floor(timerSecs/60),s=timerSecs%60;
  document.getElementById('timer-display').textContent=String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  document.getElementById('timer-arc').setAttribute('stroke-dashoffset',String(Math.round(515*(1-timerSecs/timerTotal))));
}
function toggleTimer(){
  if(timerRunning){clearInterval(timerInterval);timerRunning=false;document.getElementById('timer-toggle').textContent='▶ Resume';}
  else{
    timerRunning=true;document.getElementById('timer-toggle').textContent='⏸ Pause';
    timerInterval=setInterval(()=>{
      if(timerSecs>0){timerSecs--;updateTimerDisplay();if(timerSecs%60===0){focusMinutes++;updateStats();}}
      else{clearInterval(timerInterval);timerRunning=false;document.getElementById('timer-status').textContent='Done! Take a break.';document.getElementById('timer-toggle').textContent='▶ Start';alert('Focus block complete! Great work.');}
    },1000);
  }
}
function resetTimer(){clearInterval(timerInterval);timerRunning=false;document.getElementById('timer-toggle').textContent='▶ Start';document.getElementById('timer-status').textContent='Focus block';setMode();}
function setMode(){const m=parseInt(document.getElementById('timer-mode').value);timerTotal=m*60;timerSecs=timerTotal;document.getElementById('timer-status').textContent=m<=15?'Break time':'Focus block';updateTimerDisplay();}

const moods=[{e:'😄',l:'great'},{e:'🙂',l:'good'},{e:'😐',l:'okay'},{e:'😤',l:'restless'},{e:'😢',l:'upset'}];
function renderMoods(){
  const el=document.getElementById('mood-panel');
  if(!kids.length){el.innerHTML='<p style="font-size:13px;color:var(--text2)">Add kids on the Dashboard first.</p>';return;}
  el.innerHTML=kids.map((k,ki)=>`
    <div style="margin-bottom:16px">
      <div style="font-size:11px;font-weight:700;color:var(--violet3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">${k.name}</div>
      <div class="mood-grid">${moods.map((m,mi)=>`<button class="mood-btn" onclick="selectMood(${ki},${mi},this)"><div class="mood-emoji">${m.e}</div><div class="mood-lbl">${m.l}</div></button>`).join('')}</div>
    </div>`).join('');
}
function selectMood(ki,mi,btn){
  btn.closest('.mood-grid').querySelectorAll('.mood-btn').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel');
  if(moods[mi].l==='restless'||moods[mi].l==='upset')alert(kids[ki].name+' seems '+moods[mi].l+'. Try settling them with a quiet activity before your focus block.');
}

function renderTaskWhoSelect(){
  const sel=document.getElementById('task-who-select');
  sel.innerHTML='<option value="">— Select a child —</option>'+kids.map(k=>`<option value="${k.name}">${k.name}</option>`).join('');
}
function addTask(){
  const text=document.getElementById('task-input').value.trim();
  const who=document.getElementById('task-who-select').value;
  if(!text){alert('Please enter a task.');return;}
  if(!who){alert('Please select a child.');return;}
  tasks.push({id:Date.now(),text,who,done:false});
  document.getElementById('task-input').value='';
  renderTasks();
}
function toggleTask(id){const t=tasks.find(t=>t.id===id);if(t){t.done=!t.done;renderTasks();updateStats();}}
function renderTasks(){
  const el=document.getElementById('task-list');
  if(!tasks.length){el.innerHTML='<p style="font-size:13px;color:var(--text2);padding:8px 0">No tasks yet.</p>';return;}
  const byKid={};tasks.forEach(t=>{if(!byKid[t.who])byKid[t.who]=[];byKid[t.who].push(t);});
  el.innerHTML=Object.entries(byKid).map(([kid,ts])=>`
    <div class="section-kid">
      <div class="section-kid-name">${kid}</div>
      ${ts.map(t=>`<div class="task-item"><div class="task-check${t.done?' done':''}" onclick="toggleTask(${t.id})"></div><div class="task-text${t.done?' done':''}">${t.text}</div></div>`).join('')}
    </div>`).join('');
  const done=tasks.filter(t=>t.done).length;
  const tb=document.getElementById('tasks-badge');if(tb)tb.textContent=done+' done';
  updateStats();
}
function updateStats(){
  const done=tasks.filter(t=>t.done).length;
  document.getElementById('tasks-stat').textContent=done+'/'+tasks.length;
  document.getElementById('interrupt-count').textContent=interruptCount;
  const h=Math.floor(focusMinutes/60),m=focusMinutes%60;
  document.getElementById('focus-today').textContent=h+'h '+m+'m';
}
function logInterrupt(){interruptCount++;updateStats();}

const noises=[{name:'Rain',desc:'Gentle rainfall — ideal for focus',icon:'🌧'},{name:'Cafe',desc:'Coffee shop background hum',icon:'☕'},{name:'Forest',desc:'Birds, breeze, rustling leaves',icon:'🌿'},{name:'Brown noise',desc:'Deep low-frequency masking',icon:'🎧'},{name:'White noise',desc:'Consistent high-frequency mask',icon:'〰'}];
function renderNoise(){
  document.getElementById('noise-list').innerHTML=noises.map((n,i)=>`
    <div class="noise-card${activeNoise===i?' active':''}" onclick="selectNoise(${i})">
      <div class="noise-icon">${n.icon}</div>
      <div style="flex:1"><div class="noise-name">${n.name}</div><div class="noise-desc">${n.desc}</div></div>
      <span class="badge${activeNoise===i?' b-teal':' b-gray'}">${activeNoise===i?'Playing':'Play'}</span>
    </div>`).join('');
}
function selectNoise(i){activeNoise=activeNoise===i?null:i;renderNoise();}
function animateNoise(){
  noiseLevel=Math.min(100,Math.max(5,noiseLevel+(Math.random()*16-8)));
  const p=Math.round(noiseLevel);
  document.getElementById('noise-fill').style.width=p+'%';
  document.getElementById('noise-fill').style.background=p<30?'var(--teal)':p<60?'var(--amber)':'var(--rose)';
  document.getElementById('noise-text').textContent=p<30?'Quiet — great for video calls':p<60?'Moderate — okay for most calls':'Loud — use headphones or move rooms';
  setTimeout(animateNoise,1400);
}

updateTimerDisplay();renderNoise();animateNoise();updateStats();
</script>
</body>
</html>
